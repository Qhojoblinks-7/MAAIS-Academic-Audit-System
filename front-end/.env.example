# VITE_API_BASE_URL: Base URL for API endpoints.
# For production: https://your-backend.onrender.com/api/v1
# For local dev: http://localhost:3000/api/v1
VITE_API_BASE_URL="http://localhost:3000/api/v1"

# VITE_APP_URL: The URL where this app is hosted.
# For Vercel: https://maais-academic-audit-system.vercel.app
# For local dev: http://localhost:5173
VITE_APP_URL="http://localhost:5173"

# Production Notes:
# 1. Set VITE_API_BASE_URL to your Render backend URL
# 2. Set VITE_APP_URL to your Vercel frontend URL
# 3. These are exposed to the browser - never put secrets here
# 4. In Vercel: Project Settings → Environment Variables
# 5. In Render: These are for the backend only (use .env there)

